{
  "name": "intelligents",
  "version": "0.0.0",
  "private": true,
  "publisher": "local",
  "description": "Agentic CRM for VS Code — manage persistent AI coding agents, their skills, and memory. Integrates with Claude Code and GitHub Copilot.",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:intelligents.agentsView"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "intelligents",
          "title": "Intelligents",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "intelligents": [
        {
          "id": "intelligents.agentsView",
          "name": "Agents",
          "icon": "media/icon.svg",
          "contextualTitle": "Intelligents"
        }
      ]
    },
    "commands": [
      {
        "command": "intelligents.refresh",
        "title": "Refresh",
        "category": "Intelligents",
        "icon": "$(refresh)"
      },
      {
        "command": "intelligents.openForm",
        "title": "Edit",
        "category": "Intelligents"
      },
      {
        "command": "intelligents.newAgent",
        "title": "New Agent",
        "category": "Intelligents",
        "icon": "$(add)"
      },
      {
        "command": "intelligents.newSkill",
        "title": "New Skill",
        "category": "Intelligents",
        "icon": "$(add)"
      },
      {
        "command": "intelligents.duplicateAgent",
        "title": "Duplicate Agent",
        "category": "Intelligents",
        "icon": "$(copy)"
      },
      {
        "command": "intelligents.approveProposal",
        "title": "Approve Proposal",
        "category": "Intelligents",
        "icon": "$(check)"
      },
      {
        "command": "intelligents.rejectProposal",
        "title": "Reject Proposal",
        "category": "Intelligents",
        "icon": "$(close)"
      },
      {
        "command": "intelligents.launchAgent",
        "title": "Launch Agent",
        "category": "Intelligents",
        "icon": "$(play)"
      },
      {
        "command": "intelligents.resumeSession",
        "title": "Resume Session",
        "category": "Intelligents",
        "icon": "$(debug-restart)"
      },
      {
        "command": "intelligents.newSession",
        "title": "New Session",
        "category": "Intelligents",
        "icon": "$(add)"
      },
      {
        "command": "intelligents.revealSession",
        "title": "Open Session",
        "category": "Intelligents"
      },
      {
        "command": "intelligents.archiveSession",
        "title": "Archive Session",
        "category": "Intelligents",
        "icon": "$(archive)"
      },
      {
        "command": "intelligents.deleteSession",
        "title": "Delete Session",
        "category": "Intelligents",
        "icon": "$(trash)"
      },
      {
        "command": "intelligents.sendMessage",
        "title": "Send Message",
        "category": "Intelligents",
        "icon": "$(comment)"
      },
      {
        "command": "intelligents.reviewSession",
        "title": "Review Changes",
        "category": "Intelligents",
        "icon": "$(diff)"
      },
      {
        "command": "intelligents.mergeSession",
        "title": "Merge & Archive Session",
        "category": "Intelligents",
        "icon": "$(git-merge)"
      },
      {
        "command": "intelligents.openWorktree",
        "title": "Open Worktree in New Window",
        "category": "Intelligents",
        "icon": "$(empty-window)"
      },
      {
        "command": "intelligents.deleteHistorySession",
        "title": "Delete Session Transcript",
        "category": "Intelligents",
        "icon": "$(trash)"
      },
      {
        "command": "intelligents.viewTranscript",
        "title": "View Transcript",
        "category": "Intelligents",
        "icon": "$(book)"
      },
      {
        "command": "intelligents.showMemoryPanel",
        "title": "Show Memory Panel",
        "category": "Intelligents",
        "icon": "$(eye)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "intelligents.openForm",
          "when": "false"
        },
        {
          "command": "intelligents.duplicateAgent",
          "when": "false"
        },
        {
          "command": "intelligents.approveProposal",
          "when": "false"
        },
        {
          "command": "intelligents.rejectProposal",
          "when": "false"
        },
        {
          "command": "intelligents.launchAgent",
          "when": "false"
        },
        {
          "command": "intelligents.resumeSession",
          "when": "false"
        },
        {
          "command": "intelligents.revealSession",
          "when": "false"
        },
        {
          "command": "intelligents.archiveSession",
          "when": "false"
        },
        {
          "command": "intelligents.deleteSession",
          "when": "false"
        },
        {
          "command": "intelligents.sendMessage",
          "when": "false"
        },
        {
          "command": "intelligents.reviewSession",
          "when": "false"
        },
        {
          "command": "intelligents.mergeSession",
          "when": "false"
        },
        {
          "command": "intelligents.openWorktree",
          "when": "false"
        },
        {
          "command": "intelligents.deleteHistorySession",
          "when": "false"
        },
        {
          "command": "intelligents.viewTranscript",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "intelligents.refresh",
          "when": "view == intelligents.agentsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "intelligents.newAgent",
          "when": "view == intelligents.agentsView && viewItem == category:agents",
          "group": "inline"
        },
        {
          "command": "intelligents.newSkill",
          "when": "view == intelligents.agentsView && viewItem == category:skills",
          "group": "inline"
        },
        {
          "command": "intelligents.launchAgent",
          "when": "view == intelligents.agentsView && viewItem == agent",
          "group": "navigation@1"
        },
        {
          "command": "intelligents.duplicateAgent",
          "when": "view == intelligents.agentsView && viewItem == agent",
          "group": "modify@1"
        },
        {
          "command": "intelligents.approveProposal",
          "when": "view == intelligents.agentsView && viewItem == pendingProposal",
          "group": "inline@1"
        },
        {
          "command": "intelligents.rejectProposal",
          "when": "view == intelligents.agentsView && viewItem == pendingProposal",
          "group": "inline@2"
        },
        {
          "command": "intelligents.newSession",
          "when": "view == intelligents.agentsView && viewItem == agent",
          "group": "navigation@2"
        },
        {
          "command": "intelligents.archiveSession",
          "when": "view == intelligents.agentsView && viewItem == liveSession",
          "group": "navigation@1"
        },
        {
          "command": "intelligents.deleteSession",
          "when": "view == intelligents.agentsView && viewItem == liveSession",
          "group": "navigation@2"
        },
        {
          "command": "intelligents.reviewSession",
          "when": "view == intelligents.agentsView && viewItem == liveSession",
          "group": "review@1"
        },
        {
          "command": "intelligents.mergeSession",
          "when": "view == intelligents.agentsView && viewItem == liveSession",
          "group": "review@2"
        },
        {
          "command": "intelligents.sendMessage",
          "when": "view == intelligents.agentsView && viewItem == liveSession",
          "group": "session@1"
        },
        {
          "command": "intelligents.openWorktree",
          "when": "view == intelligents.agentsView && viewItem == liveSession",
          "group": "session@2"
        },
        {
          "command": "intelligents.deleteSession",
          "when": "view == intelligents.agentsView && viewItem == archivedSession",
          "group": "navigation"
        },
        {
          "command": "intelligents.deleteHistorySession",
          "when": "view == intelligents.agentsView && viewItem == session",
          "group": "inline"
        },
        {
          "command": "intelligents.viewTranscript",
          "when": "view == intelligents.agentsView && viewItem == session",
          "group": "navigation@1"
        },
        {
          "command": "intelligents.showMemoryPanel",
          "when": "view == intelligents.agentsView && viewItem == category:memories",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "prepare": "husky",
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package",
    "harness:dashboard": "bun run --cwd .harness/dashboard dev",
    "harness:sync-copilot": "bun .harness/scripts/sync-copilot.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@types/node": "^20.19.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.23.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.9.4",
    "typescript": "^5.6.3"
  }
}
