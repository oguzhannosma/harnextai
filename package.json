{
  "name": "harnextai",
  "displayName": "Harnext AI",
  "version": "1.0.0",
  "publisher": "oguzhannosma",
  "description": "Harness for AI coding agents — manage agents, skills, memory, and ticket workflows across Claude Code and Cursor.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oguzhannosma/harnextai.git"
  },
  "bugs": {
    "url": "https://github.com/oguzhannosma/harnextai/issues"
  },
  "homepage": "https://github.com/oguzhannosma/harnextai#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "harness",
    "agents",
    "claude",
    "cursor",
    "workflow",
    "ai"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#5B2A9E",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:harnextai.agentsView",
    "onView:harnextai.workflowView",
    "onView:harnextai.workflowIssuesView",
    "onView:harnextai.workflowSessionsView",
    "onView:harnextai.harnessDoctorView"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "harnextai",
          "title": "Harnext AI",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "harnextai": [
        {
          "id": "harnextai.agentsView",
          "name": "Agents",
          "icon": "media/icon.png",
          "contextualTitle": "Harnext AI"
        },
        {
          "id": "harnextai.workflowView",
          "name": "Workflow",
          "type": "webview",
          "icon": "media/icon.png",
          "contextualTitle": "Harnext AI"
        },
        {
          "id": "harnextai.workflowSessionsView",
          "name": "Sessions",
          "type": "webview",
          "icon": "media/icon.png",
          "contextualTitle": "Harnext AI"
        },
        {
          "id": "harnextai.workflowIssuesView",
          "name": "Issues",
          "icon": "media/icon.png",
          "contextualTitle": "Harnext AI"
        },
        {
          "id": "harnextai.harnessDoctorView",
          "name": "Doctor",
          "type": "webview",
          "icon": "media/icon.png",
          "contextualTitle": "Harnext AI"
        }
      ]
    },
    "configuration": {
      "title": "Harnext AI",
      "properties": {
        "harnextai.workflow.useDefaultRuntime": {
          "type": "boolean",
          "default": true,
          "description": "When true, Trigger Workflow uses the default runtime with no prompt. When false, show a picker (Claude Code / Cursor CLI) each time."
        },
        "harnextai.workflow.defaultRuntime": {
          "type": "string",
          "enum": [
            "claude",
            "cursor"
          ],
          "enumDescriptions": [
            "Claude Code CLI (claude)",
            "Cursor CLI (agent)"
          ],
          "default": "claude",
          "description": "Which CLI to run for Trigger Workflow when using the default (also the pre-selected option in the picker). Also used when launching harness-architect for New Agent / New Skill."
        },
        "harnextai.workflow.notifyOnAttention": {
          "type": "boolean",
          "default": false,
          "description": "When true, show an OS/VS Code notification when a workflow session becomes waiting-user or blocked."
        }
      }
    },
    "commands": [
      {
        "command": "harnextai.refresh",
        "title": "Refresh",
        "category": "Harnext AI",
        "icon": "$(refresh)"
      },
      {
        "command": "harnextai.openForm",
        "title": "Edit",
        "category": "Harnext AI"
      },
      {
        "command": "harnextai.newAgent",
        "title": "New Agent",
        "category": "Harnext AI",
        "icon": "$(add)"
      },
      {
        "command": "harnextai.newSkill",
        "title": "New Skill",
        "category": "Harnext AI",
        "icon": "$(add)"
      },
      {
        "command": "harnextai.duplicateAgent",
        "title": "Duplicate Agent",
        "category": "Harnext AI",
        "icon": "$(copy)"
      },
      {
        "command": "harnextai.approveProposal",
        "title": "Approve Proposal",
        "category": "Harnext AI",
        "icon": "$(check)"
      },
      {
        "command": "harnextai.rejectProposal",
        "title": "Reject Proposal",
        "category": "Harnext AI",
        "icon": "$(close)"
      },
      {
        "command": "harnextai.launchAgent",
        "title": "Launch Agent",
        "category": "Harnext AI",
        "icon": "$(play)"
      },
      {
        "command": "harnextai.resumeSession",
        "title": "Resume Session",
        "category": "Harnext AI",
        "icon": "$(debug-restart)"
      },
      {
        "command": "harnextai.newSession",
        "title": "New Session",
        "category": "Harnext AI",
        "icon": "$(add)"
      },
      {
        "command": "harnextai.revealSession",
        "title": "Open Session",
        "category": "Harnext AI"
      },
      {
        "command": "harnextai.archiveSession",
        "title": "Archive Session",
        "category": "Harnext AI",
        "icon": "$(archive)"
      },
      {
        "command": "harnextai.deleteSession",
        "title": "Delete Session",
        "category": "Harnext AI",
        "icon": "$(trash)"
      },
      {
        "command": "harnextai.sendMessage",
        "title": "Send Message",
        "category": "Harnext AI",
        "icon": "$(comment)"
      },
      {
        "command": "harnextai.reviewSession",
        "title": "Review Changes",
        "category": "Harnext AI",
        "icon": "$(diff)"
      },
      {
        "command": "harnextai.mergeSession",
        "title": "Merge & Archive Session",
        "category": "Harnext AI",
        "icon": "$(git-merge)"
      },
      {
        "command": "harnextai.openWorktree",
        "title": "Open Worktree in New Window",
        "category": "Harnext AI",
        "icon": "$(empty-window)"
      },
      {
        "command": "harnextai.deleteHistorySession",
        "title": "Delete Session Transcript",
        "category": "Harnext AI",
        "icon": "$(trash)"
      },
      {
        "command": "harnextai.viewTranscript",
        "title": "View Transcript",
        "category": "Harnext AI",
        "icon": "$(book)"
      },
      {
        "command": "harnextai.showMemoryPanel",
        "title": "Show Memory Panel",
        "category": "Harnext AI",
        "icon": "$(eye)"
      },
      {
        "command": "harnextai.refreshWorkflow",
        "title": "Refresh Workflow",
        "category": "Harnext AI",
        "icon": "$(refresh)"
      },
      {
        "command": "harnextai.triggerWorkflow",
        "title": "Trigger Workflow",
        "category": "Harnext AI",
        "icon": "$(rocket)"
      },
      {
        "command": "harnextai.revealWorkflowSession",
        "title": "Open Session",
        "category": "Harnext AI",
        "icon": "$(debug-start)"
      },
      {
        "command": "harnextai.openIssueOnGitHub",
        "title": "Open on GitHub",
        "category": "Harnext AI",
        "icon": "$(link-external)"
      },
      {
        "command": "harnextai.openWorkflowTerminalByIssue",
        "title": "Open Workflow Terminal",
        "category": "Harnext AI"
      },
      {
        "command": "harnextai.bootstrapHarness",
        "title": "Initialize Harness",
        "category": "Harnext AI",
        "icon": "$(sparkle)"
      },
      {
        "command": "harnextai.showHarnessDoctor",
        "title": "Show Doctor",
        "category": "Harnext AI",
        "icon": "$(heart)"
      },
      {
        "command": "harnextai.fixHarnessDoctor",
        "title": "Fix All (Doctor)",
        "category": "Harnext AI",
        "icon": "$(wrench)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "harnextai.openForm",
          "when": "false"
        },
        {
          "command": "harnextai.duplicateAgent",
          "when": "false"
        },
        {
          "command": "harnextai.approveProposal",
          "when": "false"
        },
        {
          "command": "harnextai.rejectProposal",
          "when": "false"
        },
        {
          "command": "harnextai.launchAgent",
          "when": "false"
        },
        {
          "command": "harnextai.resumeSession",
          "when": "false"
        },
        {
          "command": "harnextai.revealSession",
          "when": "false"
        },
        {
          "command": "harnextai.archiveSession",
          "when": "false"
        },
        {
          "command": "harnextai.deleteSession",
          "when": "false"
        },
        {
          "command": "harnextai.sendMessage",
          "when": "false"
        },
        {
          "command": "harnextai.reviewSession",
          "when": "false"
        },
        {
          "command": "harnextai.mergeSession",
          "when": "false"
        },
        {
          "command": "harnextai.openWorktree",
          "when": "false"
        },
        {
          "command": "harnextai.deleteHistorySession",
          "when": "false"
        },
        {
          "command": "harnextai.viewTranscript",
          "when": "false"
        },
        {
          "command": "harnextai.triggerWorkflow",
          "when": "false"
        },
        {
          "command": "harnextai.revealWorkflowSession",
          "when": "false"
        },
        {
          "command": "harnextai.openIssueOnGitHub",
          "when": "false"
        },
        {
          "command": "harnextai.openWorkflowTerminalByIssue",
          "when": "false"
        },
        {
          "command": "harnextai.fixHarnessDoctor",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "harnextai.refresh",
          "when": "view == harnextai.agentsView",
          "group": "navigation"
        },
        {
          "command": "harnextai.refreshWorkflow",
          "when": "view == harnextai.workflowView || view == harnextai.workflowIssuesView || view == harnextai.workflowSessionsView",
          "group": "navigation"
        },
        {
          "command": "harnextai.refresh",
          "when": "view == harnextai.harnessDoctorView",
          "group": "navigation"
        },
        {
          "command": "harnextai.fixHarnessDoctor",
          "when": "view == harnextai.harnessDoctorView",
          "group": "navigation@1"
        },
        {
          "command": "harnextai.bootstrapHarness",
          "when": "view == harnextai.harnessDoctorView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "harnextai.newAgent",
          "when": "view == harnextai.agentsView && viewItem == category:agents",
          "group": "inline"
        },
        {
          "command": "harnextai.newSkill",
          "when": "view == harnextai.agentsView && viewItem == category:skills",
          "group": "inline"
        },
        {
          "command": "harnextai.launchAgent",
          "when": "view == harnextai.agentsView && viewItem == agent",
          "group": "navigation@1"
        },
        {
          "command": "harnextai.duplicateAgent",
          "when": "view == harnextai.agentsView && viewItem == agent",
          "group": "modify@1"
        },
        {
          "command": "harnextai.approveProposal",
          "when": "view == harnextai.agentsView && viewItem == pendingProposal",
          "group": "inline@1"
        },
        {
          "command": "harnextai.rejectProposal",
          "when": "view == harnextai.agentsView && viewItem == pendingProposal",
          "group": "inline@2"
        },
        {
          "command": "harnextai.newSession",
          "when": "view == harnextai.agentsView && viewItem == agent",
          "group": "navigation@2"
        },
        {
          "command": "harnextai.archiveSession",
          "when": "view == harnextai.agentsView && viewItem == liveSession",
          "group": "navigation@1"
        },
        {
          "command": "harnextai.deleteSession",
          "when": "view == harnextai.agentsView && viewItem =~ /^(liveSession|archivedSession)$/",
          "group": "navigation@2"
        },
        {
          "command": "harnextai.reviewSession",
          "when": "view == harnextai.agentsView && viewItem == liveSession",
          "group": "review@1"
        },
        {
          "command": "harnextai.mergeSession",
          "when": "view == harnextai.agentsView && viewItem == liveSession",
          "group": "review@2"
        },
        {
          "command": "harnextai.sendMessage",
          "when": "view == harnextai.agentsView && viewItem == liveSession",
          "group": "session@1"
        },
        {
          "command": "harnextai.openWorktree",
          "when": "view == harnextai.agentsView && viewItem == liveSession",
          "group": "session@2"
        },
        {
          "command": "harnextai.deleteHistorySession",
          "when": "view == harnextai.agentsView && viewItem == session",
          "group": "inline"
        },
        {
          "command": "harnextai.viewTranscript",
          "when": "view == harnextai.agentsView && viewItem == session",
          "group": "navigation@1"
        },
        {
          "command": "harnextai.showMemoryPanel",
          "when": "view == harnextai.agentsView && viewItem == category:memories",
          "group": "inline"
        },
        {
          "command": "harnextai.triggerWorkflow",
          "when": "view == harnextai.workflowIssuesView && viewItem == githubIssue",
          "group": "inline@1"
        },
        {
          "command": "harnextai.revealWorkflowSession",
          "when": "view == harnextai.workflowIssuesView && viewItem == githubIssueWithSession",
          "group": "inline@1"
        },
        {
          "command": "harnextai.openIssueOnGitHub",
          "when": "view == harnextai.workflowIssuesView && viewItem =~ /^githubIssue/",
          "group": "inline@2"
        }
      ]
    }
  },
  "scripts": {
    "prepare": "husky",
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package",
    "harness:dashboard": "bun run --cwd .harness/dashboard dev",
    "harness:sync-copilot": "bun .harness/scripts/sync-copilot.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@types/node": "^20.19.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.23.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.9.4",
    "typescript": "^5.6.3"
  }
}
